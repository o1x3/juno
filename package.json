{
  "name": "juno",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "juno": "./src/cli/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli/index.tsx",
    "build": "bun build ./src/cli/index.tsx --outfile ./dist/juno.js --target bun",
    "build:compile": "bun build ./src/cli/index.tsx --compile --outfile ./dist/juno",
    "check": "biome check .",
    "format": "biome format --write .",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "release": "./scripts/release.sh",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "ai": "^5.0.0",
    "citty": "^0.1.6",
    "get-east-asian-width": "^1.5.0",
    "ink": "^6.3.1",
    "marked": "^18.0.3",
    "react": "^19.2.0",
    "react-devtools-core": "^7.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/bun": "^1.3.5",
    "@types/react": "^19.2.2",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
